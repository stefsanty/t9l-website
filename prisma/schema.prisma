generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  ADMIN
  VIEWER
}

model User {
  id         String   @id @default(cuid())
  lineId     String?  @unique
  name       String?
  pictureUrl String?
  // v1.28.0 (stage α.5) — NextAuth PrismaAdapter writes the OAuth profile
  // image to `User.image` by convention. Existing code reads `pictureUrl`
  // (LINE-specific from PR 6 trackLineLogin); the adapter writes `image`.
  // Both kept for the dual-population window. Stage 4 consolidates onto
  // `image` and drops `pictureUrl` once all read sites switch over.
  image      String?
  role       Role     @default(VIEWER)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Stage 1 of account-player-rework (v1.27.0). 1:1 link to the canonical
  // Player profile this human is associated with. Nullable because:
  //   (a) admin-credentials Users have no Player counterpart,
  //   (b) brand-new LINE users sign in BEFORE picking a Player slot.
  // The 1:1 is enforced by @unique. The reverse mirror lives on
  // Player.userId. Stage 2 wires the @relation; stage 1 keeps the columns
  // independent so the migration is fully additive (no FK to fail).
  playerId   String?  @unique

  // Stage α.5 of account-player-rework (v1.28.0). NextAuth Prisma adapter
  // requires both columns on User. Both nullable: LINE OAuth doesn't always
  // provide an email, only Google OAuth and EmailProvider (magic link)
  // guarantee a verified address. PostgreSQL @unique fires only when the
  // value is non-null, so two LINE users with no email can coexist.
  email         String?    @unique
  emailVerified DateTime?

  accounts      Account[]
}

// Stage α.5 of account-player-rework (v1.28.0). NextAuth adapter Account
// table — multi-provider join. One User can have many Account rows: e.g.
// Stefan signs in with LINE, later adds Google; both rows point at his
// single User.id. Resolution at JWT time goes
// (provider, providerAccountId) → Account.userId → User.
//
// Schema mirrors @auth/prisma-adapter's expected shape exactly so the
// adapter wires up without custom field mapping. Field names use
// snake_case where NextAuth uses snake_case (refresh_token, access_token,
// id_token, expires_at, token_type, session_state); these match the
// adapter's expected column names directly.
//
// onDelete: Cascade — when a User is deleted, their Account rows go too
// (no point keeping the OAuth bindings of a deleted User).
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String  // "oauth" | "email" | "credentials"
  provider          String  // "line" | "google" | "email"
  providerAccountId String  // LINE sub | Google sub | email address
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Stage α.5 of account-player-rework (v1.28.0). NextAuth EmailProvider
// verification tokens — one-shot magic-link codes. The token is hashed
// before storage by NextAuth; the identifier is the email address.
// Default expiry is 10 minutes (NextAuth-managed). Composite unique on
// (identifier, token) supports the consume-and-delete flow without
// indexing both columns separately.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Venue {
  id        String   @id @default(cuid())
  name      String   @unique
  address   String?
  city      String?
  notes     String?
  url       String?
  courtSize String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gameWeeks GameWeek[]
  matches   Match[]
}

model League {
  id           String    @id @default(cuid())
  name         String
  description  String?
  subdomain    String?   @unique
  location     String
  startDate    DateTime
  endDate      DateTime?
  isDefault    Boolean   @default(false)
  primaryColor String?
  accentColor  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  leagueTeams LeagueTeam[]
  gameWeeks   GameWeek[]
  matches     Match[]
  settings    Setting[]
  invites     LeagueInvite[]

  @@index([isDefault])
}

model Team {
  id        String   @id @default(cuid())
  name      String
  shortName String?
  color     String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leagueTeams LeagueTeam[]
}

model LeagueTeam {
  id        String   @id @default(cuid())
  leagueId  String
  teamId    String
  createdAt DateTime @default(now())

  league            League                   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  team              Team                     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerAssignments PlayerLeagueAssignment[]
  homeMatches       Match[]                  @relation("HomeTeam")
  awayMatches       Match[]                  @relation("AwayTeam")
  goals             Goal[]

  @@unique([leagueId, teamId])
}

model Player {
  id         String   @id @default(cuid())
  name       String
  position   String?
  lineId     String?  @unique
  pictureUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Stage 1 of account-player-rework (v1.27.0). Mirror of User.playerId — the
  // 1:1 binding from the canonical Player profile to its global User
  // identity. Nullable through stage 3 (existing rows backfill in stage 2;
  // stage 3 reads from this column behind a Setting flag). Stage 4 drops
  // Player.lineId and makes this the only identity column.
  userId     String?  @unique

  leagueAssignments PlayerLeagueAssignment[]
  goals             Goal[]
  assists           Assist[]
  availability      Availability[]
}

model PlayerLeagueAssignment {
  id           String   @id @default(cuid())
  playerId     String
  leagueTeamId String
  fromGameWeek Int
  toGameWeek   Int?
  createdAt    DateTime @default(now())

  player     Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  leagueTeam LeagueTeam @relation(fields: [leagueTeamId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([leagueTeamId])
}

model GameWeek {
  id         String   @id @default(cuid())
  leagueId   String
  weekNumber Int
  startDate  DateTime?
  endDate    DateTime?
  venueId    String?

  league       League         @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  venue        Venue?         @relation(fields: [venueId], references: [id])
  matches      Match[]
  availability Availability[]

  @@unique([leagueId, weekNumber])
  @@index([leagueId])
}

model Match {
  id         String      @id @default(cuid())
  leagueId   String
  gameWeekId String
  homeTeamId String
  awayTeamId String
  homeScore  Int         @default(0)
  awayScore  Int         @default(0)
  venueId    String?
  playedAt   DateTime
  endedAt    DateTime?
  status     MatchStatus @default(SCHEDULED)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  league   League     @relation(fields: [leagueId], references: [id])
  gameWeek GameWeek   @relation(fields: [gameWeekId], references: [id])
  homeTeam LeagueTeam @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam LeagueTeam @relation("AwayTeam", fields: [awayTeamId], references: [id])
  venue    Venue?     @relation(fields: [venueId], references: [id])
  goals    Goal[]
  assists  Assist[]

  @@unique([gameWeekId, homeTeamId, awayTeamId])
  @@index([leagueId])
  @@index([gameWeekId])
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  POSTPONED
}

model Goal {
  id            String   @id @default(cuid())
  matchId       String
  playerId      String
  scoringTeamId String
  minute        Int?
  isOwnGoal     Boolean  @default(false)
  createdAt     DateTime @default(now())

  match       Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player      Player     @relation(fields: [playerId], references: [id])
  scoringTeam LeagueTeam @relation(fields: [scoringTeamId], references: [id])
  assist      Assist?

  @@index([matchId])
  @@index([playerId])
  @@index([scoringTeamId])
}

model Assist {
  id        String   @id @default(cuid())
  matchId   String
  playerId  String
  goalId    String   @unique
  createdAt DateTime @default(now())

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id])
  goal   Goal   @relation(fields: [goalId], references: [id])

  @@index([matchId])
  @@index([playerId])
}

model Availability {
  id           String              @id @default(cuid())
  playerId     String
  gameWeekId   String
  rsvp         RsvpStatus?
  participated ParticipatedStatus?
  updatedAt    DateTime            @updatedAt

  player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  gameWeek GameWeek @relation(fields: [gameWeekId], references: [id], onDelete: Cascade)

  @@unique([playerId, gameWeekId])
  @@index([gameWeekId])
  @@index([playerId])
}

model Setting {
  id        String   @id @default(cuid())
  category  String
  key       String
  leagueId  String?
  value     String
  updatedAt DateTime @updatedAt

  league League? @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([category, key, leagueId])
}

enum RsvpStatus {
  GOING
  UNDECIDED
  NOT_GOING
}

enum ParticipatedStatus {
  JOINED
  NO_SHOWED
}

// Tracks every distinct LINE user that has authenticated against the public
// site, regardless of whether they've been linked to a Player record yet.
// Populated upsert-on-login from the next-auth JWT callback (lib/auth.ts).
//
// Drives the admin "Assign Player" Flow B dropdown: orphan = LineLogin row
// whose `lineId` does not appear on any `Player.lineId`. Composite index on
// (lastSeenAt) supports sorting orphans by recent activity in the admin UI.
model LineLogin {
  id          String   @id @default(cuid())
  lineId      String   @unique
  name        String?
  pictureUrl  String?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @updatedAt

  @@index([lastSeenAt])
}

// Stage 1 of account-player-rework (v1.27.0). The join gate that will
// eventually replace the open `/assign-player` picker (deferred — picker
// stays live alongside per user-decided 2026-05-01).
//
// Two flavors:
//   - CODE:     a shared code (e.g. "T9L-2026-K7M9") that any user can
//               redeem to claim ONE unlinked Player slot in the league's
//               roster. Used for chat-group announcements.
//   - PERSONAL: a code pre-bound to a specific Player via `targetPlayerId`.
//               Recipient lands directly on a "Confirm: you are X" screen
//               with no picker. Used for admin pre-staging of known players.
//
// Stage 1 introduces the table only. Reads/writes added in PRs #5/#6.
// Cascades on League delete — invites for a deleted league are meaningless,
// and we'd rather have the row vanish than dangle.
//
// `expiresAt` semantics: NULL = never expires (admin opt-out). The default
// "+7 days from creation" is enforced at the application layer (see
// outputs/account-player-rework-plan.md §5 "Default expiry") rather than at
// the schema level — Prisma can't express `now() + interval` defaults.
model LeagueInvite {
  id              String     @id @default(cuid())
  leagueId        String
  code            String     @unique
  kind            InviteKind
  targetPlayerId  String?
  createdById     String?
  expiresAt       DateTime?
  maxUses         Int?
  usedCount       Int        @default(0)
  revokedAt       DateTime?
  createdAt       DateTime   @default(now())

  league          League     @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([leagueId])
  @@index([code])
}

enum InviteKind {
  CODE
  PERSONAL
}
