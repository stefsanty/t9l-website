generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  ADMIN
  VIEWER
}

model User {
  id         String   @id @default(cuid())
  lineId     String?  @unique
  name       String?
  pictureUrl String?
  role       Role     @default(VIEWER)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Venue {
  id        String   @id @default(cuid())
  name      String   @unique
  address   String?
  city      String?
  notes     String?
  url       String?
  courtSize String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gameWeeks GameWeek[]
  matches   Match[]
}

model League {
  id           String    @id @default(cuid())
  name         String
  description  String?
  subdomain    String?   @unique
  location     String
  startDate    DateTime
  endDate      DateTime?
  isDefault    Boolean   @default(false)
  primaryColor String?
  accentColor  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  leagueTeams LeagueTeam[]
  gameWeeks   GameWeek[]
  matches     Match[]
  settings    Setting[]

  @@index([isDefault])
}

model Team {
  id        String   @id @default(cuid())
  name      String
  shortName String?
  color     String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leagueTeams LeagueTeam[]
}

model LeagueTeam {
  id        String   @id @default(cuid())
  leagueId  String
  teamId    String
  createdAt DateTime @default(now())

  league            League                   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  team              Team                     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerAssignments PlayerLeagueAssignment[]
  homeMatches       Match[]                  @relation("HomeTeam")
  awayMatches       Match[]                  @relation("AwayTeam")
  goals             Goal[]

  @@unique([leagueId, teamId])
}

model Player {
  id         String   @id @default(cuid())
  name       String
  position   String?
  lineId     String?  @unique
  pictureUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  leagueAssignments PlayerLeagueAssignment[]
  goals             Goal[]
  assists           Assist[]
  availability      Availability[]
}

model PlayerLeagueAssignment {
  id           String   @id @default(cuid())
  playerId     String
  leagueTeamId String
  fromGameWeek Int
  toGameWeek   Int?
  createdAt    DateTime @default(now())

  player     Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  leagueTeam LeagueTeam @relation(fields: [leagueTeamId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([leagueTeamId])
}

model GameWeek {
  id         String   @id @default(cuid())
  leagueId   String
  weekNumber Int
  startDate  DateTime
  endDate    DateTime
  venueId    String?

  league       League         @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  venue        Venue?         @relation(fields: [venueId], references: [id])
  matches      Match[]
  availability Availability[]

  @@unique([leagueId, weekNumber])
  @@index([leagueId])
}

model Match {
  id         String      @id @default(cuid())
  leagueId   String
  gameWeekId String
  homeTeamId String
  awayTeamId String
  homeScore  Int         @default(0)
  awayScore  Int         @default(0)
  venueId    String?
  playedAt   DateTime
  endedAt    DateTime?
  status     MatchStatus @default(SCHEDULED)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  league   League     @relation(fields: [leagueId], references: [id])
  gameWeek GameWeek   @relation(fields: [gameWeekId], references: [id])
  homeTeam LeagueTeam @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam LeagueTeam @relation("AwayTeam", fields: [awayTeamId], references: [id])
  venue    Venue?     @relation(fields: [venueId], references: [id])
  goals    Goal[]
  assists  Assist[]

  @@unique([gameWeekId, homeTeamId, awayTeamId])
  @@index([leagueId])
  @@index([gameWeekId])
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  POSTPONED
}

model Goal {
  id            String   @id @default(cuid())
  matchId       String
  playerId      String
  scoringTeamId String
  minute        Int?
  isOwnGoal     Boolean  @default(false)
  createdAt     DateTime @default(now())

  match       Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player      Player     @relation(fields: [playerId], references: [id])
  scoringTeam LeagueTeam @relation(fields: [scoringTeamId], references: [id])
  assist      Assist?

  @@index([matchId])
  @@index([playerId])
  @@index([scoringTeamId])
}

model Assist {
  id        String   @id @default(cuid())
  matchId   String
  playerId  String
  goalId    String   @unique
  createdAt DateTime @default(now())

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id])
  goal   Goal   @relation(fields: [goalId], references: [id])

  @@index([matchId])
  @@index([playerId])
}

model Availability {
  id           String              @id @default(cuid())
  playerId     String
  gameWeekId   String
  rsvp         RsvpStatus?
  participated ParticipatedStatus?
  updatedAt    DateTime            @updatedAt

  player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  gameWeek GameWeek @relation(fields: [gameWeekId], references: [id], onDelete: Cascade)

  @@unique([playerId, gameWeekId])
  @@index([gameWeekId])
  @@index([playerId])
}

model Setting {
  id        String   @id @default(cuid())
  category  String
  key       String
  leagueId  String?
  value     String
  updatedAt DateTime @updatedAt

  league League? @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([category, key, leagueId])
}

enum RsvpStatus {
  GOING
  UNDECIDED
  NOT_GOING
}

enum ParticipatedStatus {
  JOINED
  NO_SHOWED
}

// Tracks every distinct LINE user that has authenticated against the public
// site, regardless of whether they've been linked to a Player record yet.
// Populated upsert-on-login from the next-auth JWT callback (lib/auth.ts).
//
// Drives the admin "Assign Player" Flow B dropdown: orphan = LineLogin row
// whose `lineId` does not appear on any `Player.lineId`. Composite index on
// (lastSeenAt) supports sorting orphans by recent activity in the admin UI.
model LineLogin {
  id          String   @id @default(cuid())
  lineId      String   @unique
  name        String?
  pictureUrl  String?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @updatedAt

  @@index([lastSeenAt])
}
