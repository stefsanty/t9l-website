generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  ADMIN
  VIEWER
}

// v1.84.0 — homepage redesign phase 1a. Three-tier league visibility for
// the upcoming `/leagues` directory + recruitment-banner gating. Replaces
// the binary `League.recruiting` toggle as the canonical signal:
//
//   PRIVATE       — invitation-only. Hidden from the public directory.
//                   Self-serve apply (`applyToLeague`) is rejected with
//                   an "invite required" message; `/join/<code>` is the
//                   sole entry path.
//   PUBLIC_CLOSED — listed in the public directory but the recruitment
//                   banner does NOT auto-mount on the league page.
//                   Self-serve apply via the modal IS accepted; useful
//                   for leagues that want to be discoverable but not
//                   actively advertise mid-season.
//   PUBLIC_OPEN   — listed in the directory AND the recruitment banner
//                   auto-mounts on `/id/<slug>` (and `/`). Self-serve
//                   apply accepted everywhere.
//
// Migration default for new and existing rows is PUBLIC_CLOSED; the
// one-shot data migration upgrades existing `League.recruiting = true`
// rows to PUBLIC_OPEN so the legacy banner-on leagues see no UX change.
// `League.recruiting` stays during the transition (admin SettingsTab
// keeps the toggle this phase) and is dropped in a later cycle once
// every read site has switched over.
enum LeagueVisibility {
  PRIVATE
  PUBLIC_CLOSED
  PUBLIC_OPEN
}

// v1.93.0 — Guest type for the per-(matchday, team) MatchdayGuest rows
// that replaced the v1.91.0 count-only `MatchdayGuestEntry` model.
// EXTERNAL = non-T9L people; LEAGUE = T9L users from another team
// filling in for this match. Used by the table-based AddGuestsModal
// (two sectioned lists) and by the synthesised pseudo-Player labels
// in the pitch + list views ("Ext Guest N" / "League Guest N").
enum GuestType {
  EXTERNAL
  LEAGUE
}

model User {
  id              String   @id @default(cuid())
  lineId          String?  @unique
  // v1.72.0 — `name` is now the linked Player's name when a Player is
  // bound (User.playerId non-null). When unlinked it falls back to
  // `authAccountName`. `authAccountName` permanently records whatever
  // the auth provider (LINE display name, Google name, email address)
  // returned at sign-in time and is never overwritten by Player edits.
  name            String?
  authAccountName String?
  pictureUrl      String?
  // v1.28.0 (stage α.5) — NextAuth PrismaAdapter writes the OAuth profile
  // image to `User.image` by convention. Existing code reads `pictureUrl`
  // (LINE-specific from PR 6 trackLineLogin); the adapter writes `image`.
  // Both kept for the dual-population window. Stage 4 consolidates onto
  // `image` and drops `pictureUrl` once all read sites switch over.
  image           String?
  role            Role     @default(VIEWER)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Stage 1 of account-player-rework (v1.27.0). 1:1 link to the canonical
  // Player profile this human is associated with. Nullable because:
  //   (a) admin-credentials Users have no Player counterpart,
  //   (b) brand-new LINE users sign in BEFORE picking a Player slot.
  // The 1:1 is enforced by @unique. The reverse mirror lives on
  // Player.userId. Stage 2 wires the @relation; stage 1 keeps the columns
  // independent so the migration is fully additive (no FK to fail).
  playerId String? @unique

  // Stage α.5 of account-player-rework (v1.28.0). NextAuth Prisma adapter
  // requires both columns on User. Both nullable: LINE OAuth doesn't always
  // provide an email, only Google OAuth and EmailProvider (magic link)
  // guarantee a verified address. PostgreSQL @unique fires only when the
  // value is non-null, so two LINE users with no email can coexist.
  email         String?   @unique
  emailVerified DateTime?

  // v1.70.0 — moved from Player. Identity proof is per-person, not
  // per-league. One person, one ID. Three additive nullable columns
  // backfilled from Player at migration time (one row per User, copied
  // up via Player.userId), then dropped from Player in the same
  // migration. URL columns hold Vercel Blob public URLs; `idUploadedAt`
  // is non-null when both URLs are uploaded successfully.
  //
  // Retention: forever (no user-facing disclosure per operator decision
  // 2026-05-02). Admin can purge via the per-row "Purge ID" action,
  // which DELs the Blob objects and nulls these columns. Used solely
  // for venue booking documentation.
  //
  // Operator gate: writes require `BLOB_READ_WRITE_TOKEN` on Vercel.
  // Without the env var, the upload route surfaces a "skip" path that
  // flips onboardingStatus → COMPLETED without writing these columns.
  idFrontUrl   String?
  idBackUrl    String?
  idUploadedAt DateTime?

  accounts Account[]

  // v1.42.0 (epic match events PR α) — audit trail for who entered each
  // MatchEvent row (admin or self-reporting player). Nullable on the
  // MatchEvent side; relation declared here so Prisma's relation graph
  // compiles.
  authoredEvents MatchEvent[]

  // v1.93.0 — audit trail for who created a MatchdayGuest row. Nullable
  // on the guest side (FK ON DELETE SET NULL) so deleting a User keeps
  // their guest rows with `createdById = NULL`. Renamed from
  // `authoredGuestEntries` (v1.91.0) when the count-only model was
  // replaced with per-row guest entries.
  authoredGuests MatchdayGuest[]

  // v1.95.0 — audit trail for admin RSVP overrides. Set when this User
  // (admin) uses the override section of the Add Guests modal to flip a
  // roster player's RSVP. Cleared on the Availability row when the
  // player re-RSVPs through `/api/rsvp`.
  overriddenAvailabilities Availability[] @relation("AvailabilityOverriddenBy")

  // v1.84.0 — homepage redesign phase 1a. Per-user preferred league for
  // the persona-aware apex. Nullable; the column is purely additive in
  // this phase (no writes yet — phase 1b wires the writes from the
  // upcoming `/leagues` directory + LeagueSwitcher).
  //
  // ON DELETE SET NULL — when a league is removed the user's pin clears
  // rather than orphaning. No `@relation` back-relation declared on
  // `League` to keep the back-relation graph small; the Prisma client
  // can read this via the explicit FK.
  defaultLeagueId String?
  defaultLeague   League? @relation("UserDefaultLeague", fields: [defaultLeagueId], references: [id], onDelete: SetNull)

  @@index([defaultLeagueId])
}

// Stage α.5 of account-player-rework (v1.28.0). NextAuth adapter Account
// table — multi-provider join. One User can have many Account rows: e.g.
// Stefan signs in with LINE, later adds Google; both rows point at his
// single User.id. Resolution at JWT time goes
// (provider, providerAccountId) → Account.userId → User.
//
// Schema mirrors @auth/prisma-adapter's expected shape exactly so the
// adapter wires up without custom field mapping. Field names use
// snake_case where NextAuth uses snake_case (refresh_token, access_token,
// id_token, expires_at, token_type, session_state); these match the
// adapter's expected column names directly.
//
// onDelete: Cascade — when a User is deleted, their Account rows go too
// (no point keeping the OAuth bindings of a deleted User).
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String // "oauth" | "email" | "credentials"
  provider          String // "line" | "google" | "email"
  providerAccountId String // LINE sub | Google sub | email address
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Stage α.5 of account-player-rework (v1.28.0). NextAuth EmailProvider
// verification tokens — one-shot magic-link codes. The token is hashed
// before storage by NextAuth; the identifier is the email address.
// Default expiry is 10 minutes (NextAuth-managed). Composite unique on
// (identifier, token) supports the consume-and-delete flow without
// indexing both columns separately.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Venue {
  id        String   @id @default(cuid())
  name      String   @unique
  address   String?
  city      String?
  notes     String?
  url       String?
  courtSize String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gameWeeks GameWeek[]
  matches   Match[]
}

model League {
  id           String    @id @default(cuid())
  name         String
  description  String?
  subdomain    String?   @unique
  location     String
  startDate    DateTime
  endDate      DateTime?
  // v1.84.0 — kept for the transition but no longer used as a routing
  // signal. Pre-v1.84.0, `getDefaultLeagueId()` resolved `/` and the
  // header brand title via `where: { isDefault: true }`. Phase 1b/1c
  // moves persona-aware routing to `User.defaultLeagueId` (per-user
  // preference) + the `/leagues` directory; this column will be dropped
  // when the last reader is migrated.
  // TODO(homepage-phase-1c): remove `isDefault` once `/` no longer
  // resolves a global default league.
  isDefault    Boolean   @default(false)
  primaryColor String?
  accentColor  String?

  // v1.84.0 — three-tier visibility. Default PUBLIC_CLOSED so a freshly
  // created league appears in the directory but the recruitment banner
  // does not auto-mount until the admin explicitly bumps it to
  // PUBLIC_OPEN. Existing rows are remapped from `League.recruiting` by
  // the one-shot migration: `recruiting = true` → PUBLIC_OPEN, else
  // PUBLIC_CLOSED. See enum docs above for the per-state semantics.
  visibility   LeagueVisibility @default(PUBLIC_CLOSED)
  // v1.73.0 — short display label for the header home button and page title.
  // Null means fall back to League.name. Backfilled for the default league.
  abbreviation String?

  // v1.60.0 — per-league toggle controlling whether the legacy open
  // `/assign-player` self-link picker is available for THIS league.
  // When true (default — backward compatible), any LINE-authenticated
  // user can claim an unlinked player slot in this league. When false,
  // the route surfaces a "self-linking disabled" message and the API
  // POST 403s; users must redeem an invite via `/join/[code]` instead.
  // DELETE is unaffected so already-linked players can still unlink.
  allowSelfLink Boolean @default(true)

  // v1.63.0 — pre-season mode. When true, the homepage swaps the
  // single-matchday banner (`NextMatchdayBanner`) for a vertically
  // compact "all matchdays at a glance" view (`CompressedMatchdaySchedule`),
  // and the `STATS` page is hidden — the header link disappears and
  // visiting `/stats` redirects to the homepage. Defaults false so
  // existing leagues behave exactly as before v1.63.0.
  preseasonMode Boolean @default(false)

  // v1.63.0 — recruiting toggle. When true, surfaces a prominent
  // "RECRUITING NOW" banner at the top of the homepage. Independent
  // of `preseasonMode` — both can be on simultaneously, each off by
  // default. Click target is currently a no-op TODO; future PR wires
  // it to a per-league recruiting CTA target.
  recruiting Boolean @default(false)

  // v1.66.0 — per-league fee in JPY (no decimals). The fallback when
  // a player's PlayerLeagueMembership has no `feeOverride` and no
  // matching `LeaguePositionFee` row exists. 0 by default — leagues
  // that haven't set up fees see "no fee" semantics in the resolver
  // and the unpaid-fee banner stays hidden.
  defaultFee Int @default(0)

  // v1.67.0 — planned-roster targets surfaced in the preseason stats
  // panel above the planned schedule. Defaults of 0 mean "not set"
  // for both numeric fields; the stats panel hides them in that case.
  // `registrationDeadline` is nullable — admins may not have set one.
  plannedPlayersPerTeam Int       @default(0)
  plannedNumberOfTeams  Int       @default(0)
  registrationDeadline  DateTime?

  // v1.75.0 — League details surface (admin-configurable, optionally
  // displayed on the public preseason homepage). `LeagueDetailsPanel`
  // renders these between PlannedRosterStats and the schedule when the
  // league is in preseason mode AND `showLeagueDetails === true`. All
  // columns are additive with safe defaults so every existing league
  // backfills to "Soccer / full-size goal / throw-ins / offside on /
  // backpass on / no duration / no format / unlimited subs / no message
  // / show on" — the operator can override any field after deploy.
  ballType               BallType     @default(SOCCER)
  goalSize               GoalSize     @default(FULL_SIZE_SOCCER)
  throwInType            ThrowInType  @default(THROW_IN)
  goalKickType           GoalKickType @default(KICK)
  offsideRule            Boolean      @default(true)
  // Backpass rule is only meaningful when ballType === FUTSAL. The
  // admin UI conditionally renders the toggle and the public panel
  // hides the row when ballType !== FUTSAL.
  backpassRule           Boolean      @default(true)
  matchDurationMinutes   Int?
  // Allowed values today: 5, 6, 7, 9, 11. Modeled as Int? rather than
  // an enum because the spec says admin picks from a dropdown but the
  // set may grow (8-aside, 12-aside) without a schema change.
  playerFormat           Int?
  unlimitedSubstitutions Boolean      @default(true)
  // Long text (multi-paragraph friendly). Persisted as TEXT in
  // Postgres via @db.Text; rendered in the public panel via
  // `whitespace-pre-line` so admin newlines survive.
  organizerMessage       String?      @db.Text
  showLeagueDetails      Boolean      @default(true)

  // v1.93.0 — per-league ID-document requirement during onboarding.
  // When true (default — backward compatible), the join + recruit forms
  // require front + back ID uploads as a hard gate (the v1.71.1
  // client-direct upload path). When false, the onboarding form hides
  // the ID section entirely and accepts submissions without files. Use
  // case: casual leagues whose admins don't need ID-on-file for venue
  // booking. Default-true preserves every existing league's UX.
  idRequired             Boolean      @default(true)

  // v1.94.0 — admin-toggleable "private join link". When true, the
  // route at `/id/<slug>/join` mounts the standard league page with
  // the recruiting banner forced ON, regardless of `visibility`. Lets
  // admins share a discoverable apply-page URL even for PRIVATE /
  // PUBLIC_CLOSED leagues without flipping the league's visibility.
  // Default-false preserves every existing league (route 404s).
  //
  // Security note: the URL is slug-based — anyone who guesses the slug
  // and tries `/join` with this on sees the recruitment page. For
  // PRIVATE leagues this is a real (if low-severity) exposure. A
  // stronger token-based variant (`privateJoinToken` + URL like
  // `/id/<slug>/join/<token>`) is documented in the v1.94.0 ledger as
  // a follow-up.
  privateJoinLinkEnabled Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leagueTeams LeagueTeam[]
  gameWeeks   GameWeek[]
  matches     Match[]
  settings    Setting[]
  invites     LeagueInvite[]

  // v1.65.0 (membership-spec rework PR 1) — back-relations for the new
  // direct League FKs on PlayerLeagueMembership and PlayerLeagueStat.
  memberships  PlayerLeagueMembership[]
  playerStats  PlayerLeagueStat[]
  // v1.66.0 — per-position fee overrides (e.g. GK = 5000, FP = 4000).
  positionFees LeaguePositionFee[]

  // v1.84.0 — back-relation for User.defaultLeagueId pins. Relation
  // declared here only to satisfy Prisma's named-relation graph; no
  // application code reads `League.usersWithDefault`.
  usersWithDefault User[] @relation("UserDefaultLeague")

  @@index([isDefault])
}

// v1.66.0 — per-league per-position fee override. When a player has a
// `PlayerLeagueMembership.position` that matches a row's `position`
// string (case-sensitive exact match), `fee` is used as the resolved
// fee for that membership UNLESS membership.feeOverride is non-null.
// Otherwise falls through to League.defaultFee. See
// `src/lib/playerFee.ts#resolvePlayerFee` for the canonical resolution
// order.
//
// The position column is `String` (not the `PlayerPosition` enum) so
// admins can use richer categorization than the four enum literals
// (e.g. "GK" + "FP" = field-player, where "FP" doesn't match any
// PlayerPosition value and so naturally falls through to defaultFee
// for non-GK players).
model LeaguePositionFee {
  id        String   @id @default(cuid())
  leagueId  String
  position  String
  fee       Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, position])
  @@index([leagueId])
}

model Team {
  id        String   @id @default(cuid())
  name      String
  shortName String?
  color     String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leagueTeams LeagueTeam[]
}

model LeagueTeam {
  id        String   @id @default(cuid())
  leagueId  String
  teamId    String
  createdAt DateTime @default(now())

  league            League                   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  team              Team                     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  // v1.65.0 — relation type renamed via @@map; field name stays through
  // this PR (rename to `playerMemberships` deferred to v1.65.4 cleanup).
  playerAssignments PlayerLeagueMembership[]
  homeMatches       Match[]                  @relation("HomeTeam")
  awayMatches       Match[]                  @relation("AwayTeam")
  // v1.90.0 — back-relation `goals Goal[]` removed; the Goal table was
  // dropped in v1.90.0 (writers/readers gone in v1.89.0). All goal data
  // lives on MatchEvent now (see beneficiaryEvents below).
  // v1.82.0 — back-relation for MatchEvent.beneficiaryTeamId.
  beneficiaryEvents MatchEvent[]             @relation("EventBeneficiary")
  // v1.93.0 — per-matchday guest rows for this team. Replaces the
  // count-only `guestEntries` back-relation from v1.91.0.
  guests            MatchdayGuest[]

  @@unique([leagueId, teamId])
}

model Player {
  id                String   @id @default(cuid())
  // v1.33.0 (PR ε of the onboarding chain) — `name` becomes nullable so
  // admins can pre-stage a roster slot (team known, name not yet) and let
  // the user fill it in via the upcoming `/join/[code]` flow (PR ζ).
  // Backward-compat: every row at v1.33.0 deploy time has a non-null name.
  name              String?
  // v1.65.4 — `Player.position` was DROPPED in v1.65.4 (membership-spec
  // rework PR 5). Position now lives on `PlayerLeagueMembership.position`
  // — per-league. Reads + writes through that field.
  lineId            String?  @unique
  pictureUrl        String?
  // v1.37.0 (PR ι) — user-uploaded profile picture (Vercel Blob).
  // Replace-only: re-upload via /account/player deletes the prior
  // asset. Distinct from `pictureUrl` (LINE-CDN mirror, written by
  // /api/assign-player on link). Render priority lives in
  // src/lib/playerAvatar.ts: profilePictureUrl > pictureUrl > static
  // fallback. Nullable — pre-ι rows have no user-uploaded asset.
  profilePictureUrl String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Stage 1 of account-player-rework (v1.27.0). Mirror of User.playerId — the
  // 1:1 binding from the canonical Player profile to its global User
  // identity. Nullable through stage 3 (existing rows backfill in stage 2;
  // stage 3 reads from this column behind a Setting flag). Stage 4 drops
  // Player.lineId and makes this the only identity column.
  userId String? @unique

  // v1.34.0 (PR ζ) — captures the onboarding form's free-form preference
  // fields (preferredTeammateIds: string[] + preferredTeammatesFreeText:
  // string + optional preferredLeagueTeamId for invites without a team
  // pre-bound). JSON shape keeps the schema flexible while ζ + η iterate
  // on the form. Nullable — admin pre-stages start with no preferences.
  onboardingPreferences Json?

  // v1.70.0 — `Player.idFrontUrl`, `Player.idBackUrl`, and
  // `Player.idUploadedAt` were MOVED to User in v1.70.0 (the
  // `move_id_to_user` migration). Identity proof is per-person, not
  // per-league. The columns were backfilled into the linked User row
  // via Player.userId then dropped here. See `User.idFrontUrl` etc.

  // v1.65.4 — `Player.applicationStatus` and `Player.applicationLeagueId`
  // were DROPPED in v1.65.4 (membership-spec rework PR 5).
  // Application status now lives on `PlayerLeagueMembership.applicationStatus`
  // — per-league. The `PlayerApplicationStatus` enum is kept because PLM
  // still uses it.

  // v1.65.0 (membership-spec rework PR 1) — date of birth, per spec
  // ("profile-level data: name, avatar, DOB"). Optional — historical
  // rows have no DOB and there's no UI surface for it yet. Future
  // surfaces (`/account/player`, admin Players tab) will populate it.
  dob DateTime?

  // v1.65.0 — relation to the renamed PlayerLeagueMembership model.
  // The Prisma model rename is done via `@@map("PlayerLeagueAssignment")`
  // so the SQL table name stays `PlayerLeagueAssignment` — no DDL rename.
  // The TypeScript-level relation field name is kept as `leagueAssignments`
  // through this PR; rename to `leagueMemberships` is deferred to v1.65.4
  // (the cleanup PR) to keep this stage purely additive.
  leagueAssignments PlayerLeagueMembership[]
  // v1.90.0 — back-relations `goals Goal[]` and `assists Assist[]`
  // removed; the Goal + Assist tables were dropped in v1.90.0 (writers/
  // readers gone in v1.89.0). Goal/assist participation now lives on
  // MatchEvent via `scoredEvents` / `assistedEvents` below.
  availability      Availability[]
  playerStats       PlayerLeagueStat[]

  // v1.42.0 (epic match events PR α) — back-relations for MatchEvent.
  // Two named relations because a Player can be either the scorer or the
  // assister (or both, on different events).
  scoredEvents   MatchEvent[] @relation("EventScorer")
  assistedEvents MatchEvent[] @relation("EventAssister")
}

// v1.33.0 (PR ε) — formal player-position enum. Four roles: goalkeeper,
// defender, midfielder, forward. Pre-ε `Player.position` was `String?`
// populated by the Sheets backfill; the enum constrains future writes
// without changing what observed values mean. Optional — FC Torpedo
// players have no positions in the source data, and admin pre-stages
// (PR ζ) start with no position until the user fills onboarding.
enum PlayerPosition {
  GK
  DF
  MF
  FW
}

// v1.64.0 — application status. APPROVED is the default for every
// existing Player at v1.64.0 deploy time (real roster members; admin-
// pre-staged or invite-redeemed). PENDING is set on new self-service
// applications via the recruiting banner; admin reviews on the Players
// tab and either approves (flips to APPROVED + creates a PlayerLeagueAssignment)
// or rejects (deletes the Player record entirely since the data was
// supplied by an unverified user).
enum PlayerApplicationStatus {
  APPROVED
  PENDING
}

// v1.65.0 (membership-spec rework PR 1) — model RENAMED from
// `PlayerLeagueAssignment` to `PlayerLeagueMembership` per the data-model
// spec ([outputs/data-model-spec-audit.md]). The SQL table name stays
// `PlayerLeagueAssignment` via `@@map`, so the migration is zero-DDL for
// the rename itself. The TypeScript Prisma client property changes from
// `prisma.playerLeagueAssignment` to `prisma.playerLeagueMembership`;
// every call site in src/, scripts/, and tests/ is updated mechanically
// in this PR.
//
// New columns on this PR:
//   - leagueId:           direct FK to League. PENDING-application
//                         memberships (no team yet) still know their
//                         league. Existing rows backfilled from the
//                         leagueTeam.leagueId join.
//   - position:           per-league. Stage-2 dual-write copies from
//                         Player.position. Stage-4 drops Player.position.
//   - jerseyNumber:       per-league, new. Optional.
//   - status:             ACTIVE / INACTIVE / SUSPENDED. New. Defaults
//                         ACTIVE for every existing row.
//   - applicationStatus:  per-league. Stage-2 dual-write copies from
//                         Player.applicationStatus. Defaults APPROVED
//                         (every existing PLM is a real member).
//   - idShared:           per-league consent flag for ID-photo sharing
//                         with this league's admins. Defaults true (the
//                         only league using ID upload today is T9L; by
//                         uploading, the player consented to T9L admins
//                         viewing).
//
// `leagueTeamId` becomes nullable because PENDING-application memberships
// don't have a team assigned yet (admin assigns on approval).
model PlayerLeagueMembership {
  id           String   @id @default(cuid())
  playerId     String
  leagueTeamId String?
  // v1.65.0 — direct FK to League. Necessary for PENDING-application
  // memberships that don't have a leagueTeam yet (admin assigns on
  // approval). For APPROVED memberships, this mirrors leagueTeam.leagueId
  // and is kept in sync by stage-2 write paths. Nullable through stage 1
  // so the additive migration doesn't fail on existing rows; backfilled
  // synchronously in the migration's UPDATE clause.
  leagueId     String?
  fromGameWeek Int
  toGameWeek   Int?
  createdAt    DateTime @default(now())

  // v1.34.0 (PR ζ) — has the user filled the onboarding form for this
  // league? Existing rows at deploy time are backfilled to COMPLETED
  // (already-active players don't get retroactively gated). New rows
  // default to NOT_YET so admin pre-stages and `/join/[code]` redemptions
  // enter the redemption flow until the form is submitted.
  onboardingStatus OnboardingStatus @default(NOT_YET)

  // v1.34.0 — audit trail for how this assignment was created. NULL on
  // backfilled rows (we don't know retroactively); ADMIN/SELF_SERVE/
  // CODE/PERSONAL on new writes. Used by ζ for the welcome page +
  // future abuse-mitigation forensics (the rework plan's A1/A2/A3 vectors).
  joinSource JoinSource?

  // v1.65.0 — per-league position. Migrates from Player.position in
  // stage 4 (v1.65.4 drop). Backfilled in the migration from
  // Player.position so existing reads return the same value via either
  // path. Optional — FC Torpedo players have no positions; admin
  // pre-stages start with no position.
  //
  // v1.82.0 — DEPRECATED (kept for one release cycle). Multi-position
  // data lives in the `positions` array below. This single-value column
  // remains as a backward-compat read-fallback for any consumer that
  // hasn't been updated. New writes dual-write: `positions[]` always
  // gets the full array; `position` mirrors `positions[0]` IF that
  // entry is one of GK/DF/MF/FW (futsal-only codes like FIXO/ALA/PIVOT
  // can't fit this enum and write null here).
  position PlayerPosition?

  // v1.82.0 — multi-position representation. Stored as canonical
  // uppercase string codes (e.g. 'GK', 'FIXO', 'ALA', 'PIVOT' for
  // futsal; 'GK', 'DF', 'MF', 'FW' for soccer). Vocabulary is per-
  // format and lives in src/lib/positions.ts. Empty array == "no
  // position recorded" (matches legacy `position IS NULL`).
  //
  // v1.86.0 — DEPRECATED (kept for backward compat). Canonical data
  // now lives in `preferredPositions` + `secondaryPositions` below.
  // This array dual-writes as concat(preferred, secondary) for any
  // consumer that hasn't been updated to read the split fields.
  //
  // Why `String[]` (Postgres native array) and not a join table:
  // positions are a fixed code list, not row data. The whole array
  // round-trips on every Player read; a join table adds Prisma include
  // ceremony and a joined query for zero referential benefit.
  positions String[] @default([])

  // v1.86.0 — split positions into preferred vs secondary.
  // preferredPositions: roles the player WANTS to play (formation
  //   algorithm fills these first; account page labels "Preferred").
  // secondaryPositions: roles the player CAN also cover (fills
  //   fallback slots; account page labels "Also plays").
  // Migration backfill: preferredPositions ← existing positions[];
  // secondaryPositions starts empty (players opt-in via editing).
  preferredPositions String[] @default([])
  secondaryPositions String[] @default([])

  // v1.65.0 — per-league jersey number. New, no backfill source.
  // Optional. Future admin UI surface populates it.
  jerseyNumber Int?

  // v1.65.0 — membership lifecycle. ACTIVE (default), INACTIVE (on
  // hiatus, retains roster slot), SUSPENDED (admin disciplinary).
  // Distinct from `applicationStatus` (gates whether the membership is
  // a real one yet) and from `toGameWeek` (which records past
  // membership ranges via fromGameWeek/toGameWeek bracketing).
  status MembershipStatus @default(ACTIVE)

  // v1.65.0 — per-league application status. Defaults APPROVED so every
  // existing row backfills to "real member". PENDING is set on new
  // self-service applications via the recruiting banner (v1.65.1
  // dual-write). Replaces `Player.applicationStatus` in stage 4
  // (v1.65.4 drop). The same memo of "which league did this person
  // apply to" that was on `Player.applicationLeagueId` is now implicit
  // in the (leagueId, applicationStatus) pair on this row.
  applicationStatus PlayerApplicationStatus @default(APPROVED)

  // v1.65.0 — per-league consent flag for the player's uploaded ID
  // (Player.idFrontUrl/idBackUrl) being viewable by THIS league's
  // admins. Defaults true on backfill (the only league using ID upload
  // today is T9L; by uploading, the player has consented to T9L admins
  // viewing). Stage-2 admin UI surfaces this for explicit per-league
  // toggling.
  idShared Boolean @default(true)

  // v1.66.0 — per-membership payment status. Defaults UNPAID; admin
  // flips to PAID via the admin Players tab (per-row toggle or bulk
  // action). `paidAt` is the timestamp the admin marked the membership
  // PAID; nulled when flipped back to UNPAID.
  paidStatus PaidStatus @default(UNPAID)
  paidAt     DateTime?

  // v1.66.0 — per-membership fee override in JPY. When non-null, takes
  // precedence over both `LeaguePositionFee.fee` and `League.defaultFee`.
  // Used for case-by-case adjustments (waivers, partial scholarships, etc.).
  // null means "use the resolved fee from position/default" — see
  // `src/lib/playerFee.ts#resolvePlayerFee` for the resolution order.
  feeOverride Int?

  // v1.80.0 — optional free-text comments submitted by the applicant at
  // registration time. Per-league (same person may write different notes
  // for different leagues). Admin-only display; not shown on public pages.
  // TEXT type — no varchar cap.
  comments String?

  // v1.87.0 — per-league retirement marker. Null = active member; non-null =
  // retired (timestamp records when the admin retired this player from this
  // league). Retired memberships stay attached to their team and keep their
  // historical stats but are excluded from roster-size calculations
  // (`plannedRosterStats.currentPlayers`, the admin teams-all `playerCount`,
  // the unpaid-fee banner). The public squad list still renders them at
  // the bottom, greyed out, with a "RETIRED" pill. Reversible via the
  // admin kebab "Unretire" action.
  retiredAt DateTime?

  player     Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  leagueTeam LeagueTeam? @relation(fields: [leagueTeamId], references: [id], onDelete: Cascade)
  league     League?     @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([leagueTeamId])
  @@index([leagueId])
  @@map("PlayerLeagueAssignment")
}

// v1.66.0 — payment status enum for PlayerLeagueMembership.paidStatus.
// PAID and UNPAID — no intermediate states (e.g. PARTIALLY_PAID) at
// v1.66; if needed, future iteration adds them. Default for new
// memberships is UNPAID; admin flips to PAID via the admin Players
// tab toggle or bulk action.
enum PaidStatus {
  PAID
  UNPAID
}

// v1.65.0 (membership-spec rework PR 1) — membership lifecycle status.
// ACTIVE: real, current member. INACTIVE: on hiatus, retains roster
// slot for re-activation. SUSPENDED: admin-imposed (disciplinary,
// payment, etc.). Distinct from `applicationStatus` (gates whether
// the membership is a real one yet — PENDING vs APPROVED) and from
// `toGameWeek` (which records past membership ranges).
enum MembershipStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// v1.65.0 (membership-spec rework PR 1) — per-league aggregate stats
// table. Schema only at v1.65.0; no read or write site populates it
// yet. Keyed on (playerId, leagueId, seasonId?) so a player's stats
// can be queried, aggregated, or reset per season without touching
// membership records. `seasonId` is nullable for now (no Season model
// yet); future stats chain may add it.
//
// Defer of the recompute logic to a future chain (out of scope for
// v1.65.x). Today's read path remains MatchEvent-derived via
// `src/lib/matchScore.ts` and `src/components/admin/StatsTab.tsx#buildScorerStatsFromEvents`.
model PlayerLeagueStat {
  id           String   @id @default(cuid())
  playerId     String
  leagueId     String
  seasonId     String?
  goals        Int      @default(0)
  assists      Int      @default(0)
  yellowCards  Int      @default(0)
  redCards     Int      @default(0)
  appearances  Int      @default(0)
  recomputedAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([playerId, leagueId, seasonId])
  @@index([leagueId])
  @@index([playerId])
}

// v1.34.0 (PR ζ) — has a player completed the onboarding form for this
// league? `NOT_YET` is the default for new assignments (admin pre-stage
// or `/join/[code]` redemption); `COMPLETED` flips when the user submits
// the form. PR θ adds an admin "Reset onboarding" action that flips
// COMPLETED back to NOT_YET while preserving the underlying data.
enum OnboardingStatus {
  NOT_YET
  COMPLETED
}

// v1.34.0 (PR ζ) — audit trail. ADMIN: admin pre-staged via PlayersTab.
// SELF_SERVE: claimed via the legacy `/assign-player` picker. CODE:
// claimed via a CODE-flavor `LeagueInvite` redemption. PERSONAL:
// claimed via a PERSONAL-flavor `LeagueInvite` redemption.
enum JoinSource {
  ADMIN
  SELF_SERVE
  CODE
  PERSONAL
}

// v1.75.0 — League details enums. SOCCER vs FUTSAL (different ball
// physics + ruleset cues); GoalSize covers the three frame sizes the
// league rents from venues; ThrowInType vs KickIn is a futsal-vs-soccer
// restart-rule cue. Default values on each enum field on `League`
// preserve existing behaviour — every league backfills to the
// soccer-with-throw-ins shape until the admin overrides.
enum BallType {
  SOCCER
  FUTSAL
}

enum GoalSize {
  FUTSAL
  YOUTH_SOCCER
  FULL_SIZE_SOCCER
}

enum ThrowInType {
  THROW_IN
  KICK_IN
}

// v1.75.7 — Goal kick restart type: standard kick (both soccer + futsal)
// or throw (handball-style formats). Default KICK covers all standard
// football-derived formats. The field is displayed alongside ThrowInType
// in the public LeagueDetailsPanel and the admin LeagueDetailsEditor.
enum GoalKickType {
  THROW
  KICK
}

model GameWeek {
  id         String    @id @default(cuid())
  leagueId   String
  weekNumber Int
  startDate  DateTime?
  endDate    DateTime?
  venueId    String?

  league       League         @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  venue        Venue?         @relation(fields: [venueId], references: [id])
  matches      Match[]
  availability Availability[]
  // v1.93.0 — per-team guest rows for this matchday. Replaces the
  // count-only `guestEntries` back-relation from v1.91.0.
  guests       MatchdayGuest[]

  @@unique([leagueId, weekNumber])
  @@index([leagueId])
}

model Match {
  id            String      @id @default(cuid())
  leagueId      String
  gameWeekId    String
  homeTeamId    String
  awayTeamId    String
  // v1.42.0 (epic match events PR α) — `homeScore`/`awayScore` become a
  // derived cache populated by `src/lib/matchScore.ts#recomputeMatchScore`
  // every time a MatchEvent row is inserted/updated/deleted. The columns
  // stay so existing read paths (StatsTab, dbToPublicLeagueData,
  // MatchdayCard) continue to work; PR δ flips reads to compute from
  // events directly via the `events` relation.
  homeScore     Int         @default(0)
  awayScore     Int         @default(0)
  // v1.42.0 — when non-null, takes precedence over the cache for display
  // (forfeits, abandoned matches, manually-corrected scores). Free-text
  // string like "3-0 (forfeit)" or "abandoned"; the resolver tries to
  // parse "H-A" shape for places that need numeric values, otherwise
  // exposes the raw string.
  scoreOverride String?
  venueId       String?
  playedAt      DateTime
  endedAt       DateTime?
  status        MatchStatus @default(SCHEDULED)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  league   League       @relation(fields: [leagueId], references: [id])
  gameWeek GameWeek     @relation(fields: [gameWeekId], references: [id])
  homeTeam LeagueTeam   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam LeagueTeam   @relation("AwayTeam", fields: [awayTeamId], references: [id])
  venue    Venue?       @relation(fields: [venueId], references: [id])
  // v1.90.0 — back-relations `goals Goal[]` and `assists Assist[]`
  // removed; the Goal + Assist tables were dropped in v1.90.0 (writers/
  // readers gone in v1.89.0). All goal data is on `events` (MatchEvent).
  events   MatchEvent[]

  @@unique([gameWeekId, homeTeamId, awayTeamId])
  @@index([leagueId])
  @@index([gameWeekId])
}

// v1.42.0 (epic match events PR α) — unified event log tied to a Match +
// Player(s). v1 only carries kind=GOAL with goalType detail (open play /
// set piece / penalty / own goal). EventKind is intentionally an enum
// rather than a string so future event types (cards, substitutions) can
// extend cleanly. minute is nullable: events without a recorded clock
// time are allowed (admin entered after-the-fact, player self-reported
// without checking the clock).
//
// Cascades on Match delete (an event without its match is meaningless).
// Does NOT cascade on Player delete — same shape as Goal/Assist; deleting
// a Player with events would FK-fail. Admin "remove from league" only
// deletes PlayerLeagueAssignment rows, not the Player itself, so this is
// the documented intent.
model MatchEvent {
  id                String    @id @default(cuid())
  matchId           String
  kind              EventKind @default(GOAL)
  // Nullable so future EventKinds (cards, subs) don't carry GoalType.
  // For kind=GOAL we expect a non-null goalType in practice; runtime
  // guards live in the admin server actions, not in the schema.
  goalType          GoalType?
  // v1.87.0 — scorerId is nullable so guest goals (scored by an
  // off-roster player who is not in our DB) can be recorded with
  // scorerId=NULL + isGuestScorer=TRUE. Real-player events keep
  // scorerId set and isGuestScorer=FALSE.
  scorerId          String?
  assisterId        String?
  minute            Int?
  // v1.82.0 — explicit beneficiary team (the LeagueTeam.id the goal
  // counts toward in the score recompute). Pre-v1.82.0 the recompute
  // resolved beneficiary by mapping `scorerId → scorer's team` and
  // flipping for OG, which assumed the scorer was on one of the match's
  // teams. Cross-team (guest) scorers break that derivation, so writes
  // post-v1.82.0 record beneficiary explicitly. Nullable for backward
  // compat with legacy rows: when null, the recompute falls back to the
  // scorer-team derivation. Indexed for the team-stats read paths.
  // v1.87.0 — REQUIRED in practice when isGuestScorer=TRUE (the
  // recompute has no scorer-team to derive from). Runtime guard lives
  // in the server actions; schema stays nullable for legacy rows.
  beneficiaryTeamId String?
  // v1.87.0 — guest flags. `isGuestScorer=TRUE` means the goal was
  // scored by an off-roster player (scorerId=NULL,
  // beneficiaryTeamId=set). `isGuestAssister=TRUE` means the assist
  // came from an off-roster player (assisterId=NULL); a separate flag
  // disambiguates "no assist" (isGuestAssister=FALSE, assisterId=NULL)
  // from "guest assist" (isGuestAssister=TRUE, assisterId=NULL).
  // Composes naturally with goalType=OWN_GOAL — a guest scoring an OG
  // is `isGuestScorer=TRUE + goalType=OWN_GOAL`.
  isGuestScorer   Boolean @default(false)
  isGuestAssister Boolean @default(false)
  // Audit who entered the event — admin (their User.id) or the player
  // themselves (their User.id via session.user.playerId → the User who
  // owns that Player). NULL on backfilled rows from the Sheets import.
  createdById       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  match           Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  scorer          Player?     @relation("EventScorer", fields: [scorerId], references: [id])
  assister        Player?     @relation("EventAssister", fields: [assisterId], references: [id])
  beneficiaryTeam LeagueTeam? @relation("EventBeneficiary", fields: [beneficiaryTeamId], references: [id])
  createdBy       User?       @relation(fields: [createdById], references: [id])

  @@index([matchId])
  @@index([scorerId])
  @@index([assisterId])
  @@index([beneficiaryTeamId])
}

enum EventKind {
  GOAL
}

enum GoalType {
  OPEN_PLAY
  SET_PIECE
  PENALTY
  OWN_GOAL
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  POSTPONED
}

// v1.90.0 — `model Goal` and `model Assist` REMOVED (step 2 of the legacy
// table cleanup begun in v1.89.0). Step 1 dropped every writer + reader,
// confirming the tables were orphaned; this PR drops them via the matching
// `drop_legacy_goal_assist` migration. All goal/assist data has lived on
// MatchEvent since v1.42.0; the legacy tables only ever held the Sheets-
// import backfill mirror, which became dead weight after v1.46.1 made
// MatchEvent the canonical source. Acknowledged orphan rows that vanish:
// `wk1-mariners-fc-vs-fenix-fc-7` Goal + 4 mirror Goals + 3 mirror Assists
// pointing at the legacy `p-guest` Player (intentional — see PR description).

model Availability {
  id           String              @id @default(cuid())
  playerId     String
  gameWeekId   String
  rsvp         RsvpStatus?
  participated ParticipatedStatus?
  updatedAt    DateTime            @updatedAt

  // v1.95.0 — admin RSVP override audit. Set when an admin uses the
  // override section of the Add Guests modal to flip a roster player's
  // RSVP on their behalf. Cleared (both → NULL) when the player
  // re-RSVPs through `/api/rsvp` — the player taking ownership back
  // means the row is no longer "overridden" in the audit sense.
  //
  // overriddenById → FK to the admin User who last overrode this row.
  // onDelete: SetNull preserves the historical override row even if
  // the admin's User is deleted later.
  // overriddenAt → distinct from `updatedAt` (which fires on every
  // touch, including user re-RSVPs).
  overriddenById String?
  overriddenAt   DateTime?

  player        Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  gameWeek      GameWeek @relation(fields: [gameWeekId], references: [id], onDelete: Cascade)
  overriddenBy  User?   @relation("AvailabilityOverriddenBy", fields: [overriddenById], references: [id], onDelete: SetNull)

  @@unique([playerId, gameWeekId])
  @@index([gameWeekId])
  @@index([playerId])
}

model Setting {
  id        String   @id @default(cuid())
  category  String
  key       String
  leagueId  String?
  value     String
  updatedAt DateTime @updatedAt

  league League? @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([category, key, leagueId])
}

enum RsvpStatus {
  GOING
  UNDECIDED
  NOT_GOING
}

enum ParticipatedStatus {
  JOINED
  NO_SHOWED
}

// Tracks every distinct LINE user that has authenticated against the public
// site, regardless of whether they've been linked to a Player record yet.
// Populated upsert-on-login from the next-auth JWT callback (lib/auth.ts).
//
// Drives the admin "Assign Player" Flow B dropdown: orphan = LineLogin row
// whose `lineId` does not appear on any `Player.lineId`. Composite index on
// (lastSeenAt) supports sorting orphans by recent activity in the admin UI.
model LineLogin {
  id          String   @id @default(cuid())
  lineId      String   @unique
  name        String?
  pictureUrl  String?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @updatedAt

  @@index([lastSeenAt])
}

// Stage 1 of account-player-rework (v1.27.0). The join gate that will
// eventually replace the open `/assign-player` picker (deferred — picker
// stays live alongside per user-decided 2026-05-01).
//
// Two flavors:
//   - CODE:     a shared code (e.g. "T9L-2026-K7M9") that any user can
//               redeem to claim ONE unlinked Player slot in the league's
//               roster. Used for chat-group announcements.
//   - PERSONAL: a code pre-bound to a specific Player via `targetPlayerId`.
//               Recipient lands directly on a "Confirm: you are X" screen
//               with no picker. Used for admin pre-staging of known players.
//
// Stage 1 introduces the table only. Reads/writes added in PRs #5/#6.
// Cascades on League delete — invites for a deleted league are meaningless,
// and we'd rather have the row vanish than dangle.
//
// `expiresAt` semantics: NULL = never expires (admin opt-out). The default
// "+7 days from creation" is enforced at the application layer (see
// outputs/account-player-rework-plan.md §5 "Default expiry") rather than at
// the schema level — Prisma can't express `now() + interval` defaults.
model LeagueInvite {
  id             String     @id @default(cuid())
  leagueId       String
  code           String     @unique
  kind           InviteKind
  targetPlayerId String?
  createdById    String?
  expiresAt      DateTime?
  maxUses        Int?
  usedCount      Int        @default(0)
  revokedAt      DateTime?
  createdAt      DateTime   @default(now())

  // v1.33.0 (PR ε) — when true, redemption (PR ζ) bypasses the onboarding
  // form and binds the User to targetPlayerId immediately. Used for
  // high-trust pre-staged PERSONAL invites where the admin already has
  // the player's data and just needs the User-Player binding established.
  // Default false — onboarding form is the safe path.
  skipOnboarding Boolean @default(false)

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([leagueId])
  @@index([code])
}

enum InviteKind {
  CODE
  PERSONAL
}

// v1.93.0 — per-guest rows replacing the v1.91.0 count-only
// `MatchdayGuestEntry` model. Each row represents a single guest
// joining a team on a matchday, with a `type` (EXTERNAL = non-T9L
// people, LEAGUE = T9L users from another team) and their own
// `positions[]` so the formation pitch + list view can treat each
// guest like any other player.
//
// `displayOrder` (0..N within each type) drives stable row ordering
// in the modal table and the synthesised pseudo-Player labels
// ("Ext Guest 1", "Ext Guest 2", ...). The label numbering is purely
// presentational — `displayOrder` itself is rebuilt server-side on
// every `setMatchdayGuests` call so the modal "delete row N" path
// can't leave gaps.
//
// Scope: any authenticated user can submit; no admin or team-
// membership gate. Replacement-by-set means each call wipes all
// existing rows for (gameWeekId, leagueTeamId) and inserts the
// submitted list in one transaction — the same semantics the
// upsert-by-key MatchdayGuestEntry shape carried, but row-shaped.
model MatchdayGuest {
  id           String   @id @default(cuid())
  gameWeekId   String
  leagueTeamId String
  type         GuestType
  positions    String[] @default([])
  displayOrder Int      @default(0)
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  gameWeek   GameWeek   @relation(fields: [gameWeekId], references: [id], onDelete: Cascade)
  leagueTeam LeagueTeam @relation(fields: [leagueTeamId], references: [id], onDelete: Cascade)
  createdBy  User?      @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([gameWeekId, leagueTeamId, type])
  @@index([gameWeekId])
  @@index([leagueTeamId])
}
